{
  "manifest_version": 3,
  "name": "TabOS",
  "version": "0.1.0",
  "description": "Intelligent tab management: virtualize inactive tabs, classify into workspaces, enforce memory budgets.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "ui/popup/index.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "ui/sidepanel/index.html"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "sidePanel",
    "contextMenus",
    "notifications",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
